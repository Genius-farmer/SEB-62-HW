const updateLanguage = async () => {
  try {
    const res = await fetch(import.meta.env.VITE_SERVER + "/lab/languages", {
      method: "PUT",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        oldLanguage: selectedLanguage,
        newLanguage: updatedLanguage,
      }),
    });

    if (!res.ok) {
      setErrorMessage("Failed to update language");
      return;
    }
    // IF THE RESPONSE IS OK, THEN REFRESH THE LIST OF LANGUAGES AND CLEAR THE SELECTION AND INPUT FIELD
    getLanguages(); // refresh list
    setSelectedLanguage(null); // clear selection
    setUpdatedLanguage(""); // clear input
  } catch (error) {
    setErrorMessage("Something went wrong");
  }
};
